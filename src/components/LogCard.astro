---
interface Props {
  title: string;
  slug: string;
  summary: string;
  regionLabel: string;
  sequence: number;
  hero?: string | null;
  unfinished?: boolean;
  places?: string[];
}

const { title, slug, summary, regionLabel, sequence, hero, unfinished, places = [] } = Astro.props;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-navy-900/10 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-white/10 dark:bg-navy-900"
>
  <a href={`/voyage/${slug}/`} class="block no-underline">
    <div class="relative aspect-[16/10] overflow-hidden bg-navy-800">
      {
        hero ? (
          <img
            src={hero}
            alt=""
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-gradient-to-br from-navy-800 to-teal-600/40 text-sand-100/60 text-sm">
            {unfinished ? 'Chapter unfinished' : regionLabel}
          </div>
        )
      }
      <span
        class="absolute left-3 top-3 rounded-full bg-navy-950/70 px-2.5 py-0.5 text-xs font-medium text-sand-100 backdrop-blur"
      >
        #{sequence}
      </span>
      {
        unfinished && (
          <span class="absolute right-3 top-3 rounded-full bg-coral/90 px-2.5 py-0.5 text-xs font-medium text-white">
            Unfinished
          </span>
        )
      }
    </div>
    <div class="flex flex-1 flex-col gap-2 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        {regionLabel}
      </p>
      <h2 class="font-display text-xl font-semibold leading-snug text-navy-900 dark:text-sand-100">
        {title}
      </h2>
      <p class="text-sm leading-relaxed text-muted dark:text-sand-200/70">{summary}</p>
      {
        places.length > 0 && (
          <p class="mt-auto pt-2 text-xs text-navy-700/60 dark:text-sand-200/50">{places.join(' · ')}</p>
        )
      }
    </div>
  </a>
</article>
