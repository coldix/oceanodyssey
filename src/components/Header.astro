---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const links = [
  { href: '/voyage/', label: 'Voyage' },
  { href: '/map/', label: 'Map' },
  { href: '/gallery/', label: 'Gallery' },
  { href: '/hinewai/', label: 'Hinewai' },
  { href: '/people/', label: 'People' },
  { href: '/guestbook/', label: 'Guestbook' },
  { href: '/about/', label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 border-b border-navy-900/10 bg-paper/90 backdrop-blur-md dark:border-white/10 dark:bg-navy-950/90"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="group flex items-baseline gap-2 no-underline">
      <span class="font-display text-xl font-semibold tracking-tight text-navy-900 dark:text-sand-100 sm:text-2xl">
        Ocean Odyssey
      </span>
      <span class="hidden text-xs uppercase tracking-[0.2em] text-teal-600 dark:text-teal-400 sm:inline">
        Hinewai
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-full px-3 py-1.5 text-sm font-medium transition-colors no-underline',
              isActive(link.href)
                ? 'bg-navy-900 text-sand-100 dark:bg-teal-600 dark:text-white'
                : 'text-navy-800 hover:bg-navy-900/5 dark:text-sand-100/90 dark:hover:bg-white/10',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <button
        type="button"
        id="nav-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-navy-900/15 text-navy-900 dark:border-white/15 dark:text-sand-100 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-navy-900/10 px-4 py-3 dark:border-white/10 lg:hidden">
    <nav class="flex flex-col gap-1" aria-label="Mobile">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium no-underline',
              isActive(link.href)
                ? 'bg-navy-900 text-sand-100 dark:bg-teal-600'
                : 'text-navy-800 dark:text-sand-100',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = panel?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
