---
/**
 * Ocean Odyssey v1.1.0
 * Designed by Colin Dixon + Grok · Website by https://oze.au
 *
 * Serves WebP with JPEG/PNG fallback for local photos.
 */
import { isLocalJpeg, toWebpSrc } from '../lib/images';

interface Props {
  src: string;
  alt?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number | string;
  height?: number | string;
  decoding?: 'async' | 'auto' | 'sync';
}

const {
  src,
  alt = '',
  class: className = '',
  loading = 'lazy',
  fetchpriority,
  width,
  height,
  decoding = 'async',
} = Astro.props;

const useWebp = isLocalJpeg(src);
const webp = useWebp ? toWebpSrc(src) : null;
---

{
  useWebp && webp ? (
    <picture class={className}>
      <source srcset={webp} type="image/webp" />
      <img
        src={src}
        alt={alt}
        class={className}
        loading={loading}
        fetchpriority={fetchpriority}
        width={width}
        height={height}
        decoding={decoding}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      width={width}
      height={height}
      decoding={decoding}
    />
  )
}
