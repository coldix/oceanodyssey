---
/** Ocean Odyssey v1.0.0 | Designed by Colin Dixon + Grok | 2026-07-16 10:32:00 AEST (Melbourne) | Website by https://oze.au */
import BaseLayout from '../layouts/BaseLayout.astro';
import Picture from '../components/Picture.astro';

const peterBlurb =
  'Peter Knight — sailor, storyteller, and the voice behind the Ocean Odyssey logs. With Jean he prepared Hinewai for years, then wrote home from every leg of the voyage with humour, practicality and an open heart.';
const jeanBlurb =
  'Jean Hutson-Knight — partner in the adventure, navigator of people and places as much as charts. Her presence runs through the photographs and the long stays — Darwin, the orang-utans, the parties and the hard yards on the hard.';
---

<BaseLayout
  title="People — Ocean Odyssey"
  description="Meet Peter Knight, Jean Hutson-Knight, and the friends who joined Hinewai along the way."
  image="/images/pjwedpk.jpg"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        The crew
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-navy-900 dark:text-sand-100">
        Peter &amp; Jean
      </h1>
      <p class="mt-4 text-lg text-muted dark:text-sand-200/75">
        Irrespective of whether we knew you already, or you joined because of a shared love of
        travel, adventure and getting wet — everyone on these pages was a friend of the voyage.
      </p>
    </header>

    <section class="mt-12 grid gap-8 md:grid-cols-2">
      <article class="overflow-hidden rounded-2xl border border-navy-900/10 bg-white dark:border-white/10 dark:bg-navy-900">
        <Picture src="/images/pjwedpk.jpg" alt="Peter Knight" class="aspect-[4/5] w-full object-cover" loading="eager" />
        <div class="p-6">
          <h2 class="font-display text-2xl font-semibold text-navy-900 dark:text-sand-100">
            Peter Knight
          </h2>
          <p class="mt-3 leading-relaxed text-muted dark:text-sand-200/75">{peterBlurb}</p>
          <div class="mt-4 flex gap-3">
            <Picture src="/images/petersitsmile.jpg" alt="" class="h-20 w-16 rounded object-cover" loading="lazy" />
            <Picture src="/images/petersun.jpg" alt="" class="h-20 w-16 rounded object-cover" loading="lazy" />
            <Picture src="/images/peterwithbook.jpg" alt="" class="h-20 w-16 rounded object-cover" loading="lazy" />
          </div>
        </div>
      </article>

      <article class="overflow-hidden rounded-2xl border border-navy-900/10 bg-white dark:border-white/10 dark:bg-navy-900">
        <Picture src="/images/pjwedjh.jpg" alt="Jean Hutson-Knight" class="aspect-[4/5] w-full object-cover" loading="eager" />
        <div class="p-6">
          <h2 class="font-display text-2xl font-semibold text-navy-900 dark:text-sand-100">
            Jean Hutson-Knight
          </h2>
          <p class="mt-3 leading-relaxed text-muted dark:text-sand-200/75">{jeanBlurb}</p>
          <div class="mt-4 flex gap-3">
            <Picture src="/images/Jean&BassStrait.jpg" alt="" class="h-20 w-20 rounded object-cover" loading="lazy" />
            <Picture src="/images/jeandive2.jpg" alt="" class="h-20 w-20 rounded object-cover" loading="lazy" />
            <Picture src="/images/wetjean3.jpg" alt="" class="h-20 w-20 rounded object-cover" loading="lazy" />
          </div>
        </div>
      </article>
    </section>

    <section class="mt-16">
      <h2 class="font-display text-2xl font-semibold text-navy-900 dark:text-sand-100">
        Friends along the way
      </h2>
      <p class="mt-3 max-w-2xl text-muted dark:text-sand-200/75">
        The logs name many who shared watches, workshops, parties and passages — Simon, Pommy,
        Will, Mike, and others. Their faces appear throughout the voyage chapters.
      </p>
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          [
            '/images/MotleyCrew.jpg',
            '/images/Pommy.jpg',
            '/images/L22-Simon.jpg',
            '/images/L20-Simon.jpg',
          ].map((src) => (
            <Picture src={src} alt="Friends of the voyage" class="aspect-square rounded-xl object-cover" loading="lazy" />
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
