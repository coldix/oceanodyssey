---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogCard from '../../components/LogCard.astro';
import { getAllLogs, REGIONS } from '../../lib/logs';

const logs = await getAllLogs();
const byRegion = REGIONS.map((r) => ({
  ...r,
  logs: logs.filter((l) => l.data.region === r.id),
})).filter((g) => g.logs.length > 0);
---

<BaseLayout
  title="The Voyage Log — Ocean Odyssey"
  description="Every chapter of Hinewai’s voyage from Melbourne toward the UK — Peter’s journals preserved as a continuous story."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        Tales from Hinewai
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-navy-900 dark:text-sand-100 sm:text-5xl">
        The voyage log
      </h1>
      <p class="mt-4 text-lg text-muted dark:text-sand-200/75">
        Based simply on the emails sent to friends — which, dear reader, we are proud to include you
        as well. Chapters run in sailing order, from leaving Melbourne to the unfinished legs that
        Peter never quite finished writing up.
      </p>
    </header>

    <!-- Region jump -->
    <nav class="mt-8 flex flex-wrap gap-2" aria-label="Regions">
      {
        byRegion.map((g) => (
          <a
            href={`#${g.id}`}
            class="rounded-full border border-navy-900/10 px-3 py-1 text-sm text-navy-800 no-underline hover:border-teal-600 dark:border-white/15 dark:text-sand-100"
          >
            {g.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-14 space-y-16">
      {
        byRegion.map((group) => (
          <section id={group.id} class="scroll-mt-24">
            <div class="mb-6 flex items-baseline gap-3 border-b border-navy-900/10 pb-3 dark:border-white/10">
              <h2 class="font-display text-2xl font-semibold text-navy-900 dark:text-sand-100">
                {group.label}
              </h2>
              <span class="text-sm text-muted dark:text-sand-200/50">
                {group.logs.length} chapter{group.logs.length === 1 ? '' : 's'}
              </span>
            </div>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {group.logs.map((log) => (
                <LogCard
                  title={log.data.title}
                  slug={log.data.slug}
                  summary={log.data.summary}
                  regionLabel={log.data.regionLabel}
                  sequence={log.data.sequence}
                  hero={log.data.hero}
                  unfinished={log.data.unfinished}
                  places={log.data.places}
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
