---
/** Ocean Odyssey v1.0.0 | Designed by Colin Dixon + Grok | 2026-07-16 10:32:00 AEST (Melbourne) | Website by https://oze.au */
import BaseLayout from '../layouts/BaseLayout.astro';
import seedEntries from '../data/guestbook.json';
---

<BaseLayout
  title="Guestbook — Ocean Odyssey"
  description="Sign the Ocean Odyssey guestbook — leave a memory for Peter, Jean, and Hinewai."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header>
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        Visitors
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-navy-900 dark:text-sand-100">
        Guestbook
      </h1>
      <p class="mt-4 text-lg text-muted dark:text-sand-200/75">
        Leave a memory, a fair-winds wish, or a note for Jean. Messages are moderated before they
        appear publicly.
      </p>
    </header>

    <!-- Sign form -->
    <form
      id="guestbook-form"
      class="mt-10 space-y-4 rounded-2xl border border-navy-900/10 bg-white p-6 dark:border-white/10 dark:bg-navy-900 sm:p-8"
    >
      <h2 class="font-display text-xl font-semibold text-navy-900 dark:text-sand-100">
        Sign the book
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block text-sm">
          <span class="font-medium text-navy-800 dark:text-sand-100">Name *</span>
          <input
            required
            name="name"
            type="text"
            maxlength="80"
            class="mt-1 w-full rounded-lg border border-navy-900/15 bg-paper px-3 py-2 text-navy-900 dark:border-white/15 dark:bg-navy-950 dark:text-sand-100"
          />
        </label>
        <label class="block text-sm">
          <span class="font-medium text-navy-800 dark:text-sand-100">Where from</span>
          <input
            name="location"
            type="text"
            maxlength="80"
            class="mt-1 w-full rounded-lg border border-navy-900/15 bg-paper px-3 py-2 text-navy-900 dark:border-white/15 dark:bg-navy-950 dark:text-sand-100"
          />
        </label>
      </div>
      <label class="block text-sm">
        <span class="font-medium text-navy-800 dark:text-sand-100">Email (not published)</span>
        <input
          name="email"
          type="email"
          maxlength="120"
          class="mt-1 w-full rounded-lg border border-navy-900/15 bg-paper px-3 py-2 text-navy-900 dark:border-white/15 dark:bg-navy-950 dark:text-sand-100"
        />
      </label>
      <label class="block text-sm">
        <span class="font-medium text-navy-800 dark:text-sand-100">Message *</span>
        <textarea
          required
          name="message"
          rows="5"
          maxlength="2000"
          class="mt-1 w-full rounded-lg border border-navy-900/15 bg-paper px-3 py-2 text-navy-900 dark:border-white/15 dark:bg-navy-950 dark:text-sand-100"
        ></textarea>
      </label>
      <!-- honeypot -->
      <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
      <button
        type="submit"
        class="rounded-full bg-teal-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-teal-500"
      >
        Send message
      </button>
      <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
    </form>

    <!-- Entries -->
    <section class="mt-14" aria-label="Guestbook entries">
      <h2 class="font-display text-2xl font-semibold text-navy-900 dark:text-sand-100">
        Recent messages
      </h2>
      <ul id="guestbook-entries" class="mt-6 space-y-4">
        {
          seedEntries
            .filter((e) => e.approved)
            .map((e) => (
              <li class="rounded-2xl border border-navy-900/10 bg-white p-5 dark:border-white/10 dark:bg-navy-900">
                <p class="text-navy-900 dark:text-sand-100 leading-relaxed">“{e.message}”</p>
                <p class="mt-3 text-sm text-muted dark:text-sand-200/60">
                  — {e.name}
                  {e.location ? `, ${e.location}` : ''}
                  <span class="opacity-60"> · {e.date}</span>
                </p>
              </li>
            ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('guestbook-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!form || !status) return;
    status.textContent = 'Sending…';
    status.className = 'text-sm text-muted';

    const data = new FormData(form);
    // honeypot
    if (data.get('website')) {
      status.textContent = 'Thanks — your message has been received.';
      form.reset();
      return;
    }

    const payload = {
      name: String(data.get('name') || '').trim(),
      location: String(data.get('location') || '').trim(),
      email: String(data.get('email') || '').trim(),
      message: String(data.get('message') || '').trim(),
    };

    try {
      const res = await fetch('/api/guestbook.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        status.textContent =
          'Thank you. Your message is held for moderation and will appear once approved.';
        status.className = 'text-sm text-teal-600 dark:text-teal-400';
        form.reset();
        return;
      }

      // Fallback: mailto
      throw new Error('API unavailable');
    } catch {
      const subject = encodeURIComponent('Ocean Odyssey guestbook: ' + payload.name);
      const body = encodeURIComponent(
        `Name: ${payload.name}\nFrom: ${payload.location}\nEmail: ${payload.email}\n\n${payload.message}`
      );
      status.innerHTML = `The live guestbook API isn’t available here yet. Please email your message instead: <a class="underline" href="mailto:info@oceanodyssey.net?subject=${subject}&body=${body}">info@oceanodyssey.net</a>`;
      status.className = 'text-sm text-muted dark:text-sand-200/70';
    }
  });
</script>
