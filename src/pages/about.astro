import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Ocean Odyssey"
  description="About the Ocean Odyssey website — a lasting record of Peter and Jean’s voyage aboard Hinewai."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header>
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        This site
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-navy-900 dark:text-sand-100">
        About Ocean Odyssey
      </h1>
    </header>

    <div class="prose-log mt-10">
      <p>
        Ocean Odyssey records the voyage of <em>Hinewai</em> and the words and photographs of
        <strong>Peter Knight</strong> and <strong>Jean Hutson-Knight</strong>. This site was rebuilt
        so their story remains easy to find, beautiful to read, and free to explore.
      </p>
      <p>
        Peter built the original website by hand in the early 2000s — a labour of love that grew
        with every email home from the boat. After he died, Jean asked that the site be renewed as a
        proper home for the voyage: the logs, the pictures, the yacht, and the people.
      </p>
      <h2>What you’ll find</h2>
      <ul>
        <li>The full voyage log from Melbourne through the Red Sea to Turkey (and notes for later legs never finished online)</li>
        <li>An interactive route map</li>
        <li>Galleries including orang-utans at Kumai, Aden, and Suakin</li>
        <li>Hinewai’s story and particulars</li>
        <li>A guestbook for friends and fellow sailors</li>
      </ul>
      <h2>The original site</h2>
      <p>
        The classic FrontPage-era site is preserved at
        <a href="/old/">oceanodyssey.net/old/</a> for anyone who wants to see it as Peter left it.
      </p>
      <h2>Copyright</h2>
      <p>
        All original writing and photography remain copyright Ocean Odyssey / the authors. Please
        don’t republish wholesale without permission — a link and a kind word are always welcome.
      </p>
      <h2>Contact</h2>
      <p>
        Questions, memories, or photographs from the later legs?
        <a href="/contact/">Get in touch</a>.
      </p>
    </div>
  </div>
</BaseLayout>
