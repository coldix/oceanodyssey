---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogCard from '../components/LogCard.astro';
import { getAllLogs, REGIONS } from '../lib/logs';

const logs = await getAllLogs();
const featured = logs.filter((l) =>
  ['lombok-kumai', 'aden-red-sea', 'thailand-kings-cup'].includes(l.data.slug)
);
const firstLog = logs.find((l) => !l.data.unfinished);
const heroImage = '/images/HinewaiCairns.jpg';
---

<BaseLayout
  title="Ocean Odyssey — Sailing the World aboard Hinewai"
  description="Melbourne to the Mediterranean — the voyage of Hinewai, told in the words and photographs of Peter Knight and Jean Hutson-Knight."
  image={heroImage}
>
  <!-- Hero -->
  <section class="relative min-h-[78vh] flex items-end overflow-hidden">
    <img
      src={heroImage}
      alt="Hinewai at anchor"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/55 to-navy-950/25"></div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-4 pb-16 pt-32 sm:px-6 animate-fade-up">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-teal-400">A sailing memoir</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold leading-tight text-white sm:text-5xl md:text-6xl">
        Melbourne to the Mediterranean — and the long way home
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-sand-100/90 leading-relaxed">
        Ocean Odyssey records the voyage of <em>Hinewai</em> and the words and photographs of
        <strong>Peter Knight</strong> and <strong>Jean Hutson-Knight</strong>. Rebuilt so their story
        remains easy to find, beautiful to read, and free to explore.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={firstLog ? `/voyage/${firstLog.data.slug}/` : '/voyage/'}
          class="inline-flex items-center rounded-full bg-teal-600 px-6 py-3 text-sm font-semibold text-white no-underline shadow-lg transition hover:bg-teal-500"
        >
          Start the voyage
        </a>
        <a
          href="/map/"
          class="inline-flex items-center rounded-full border border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white no-underline backdrop-blur transition hover:bg-white/20"
        >
          Explore the map
        </a>
      </div>
    </div>
  </section>

  <!-- Journey chips -->
  <section class="border-b border-navy-900/10 bg-white dark:border-white/10 dark:bg-navy-900">
    <div class="mx-auto flex max-w-6xl gap-2 overflow-x-auto px-4 py-4 sm:px-6">
      {
        REGIONS.map((r) => (
          <a
            href={`/voyage/#${r.id}`}
            class="shrink-0 rounded-full border border-navy-900/10 px-4 py-1.5 text-sm text-navy-800 no-underline transition hover:border-teal-600 hover:text-teal-600 dark:border-white/15 dark:text-sand-100 dark:hover:border-teal-400 dark:hover:text-teal-400"
          >
            {r.label}
          </a>
        ))
      }
    </div>
  </section>

  <!-- Intro -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="font-display text-3xl font-semibold text-navy-900 dark:text-sand-100 sm:text-4xl">
          Or how every time Jean and Peter make a plan, God laughs
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-muted dark:text-sand-200/75">
          After years of fitting out a steel Roberts Mauritius ketch named <em>Hinewai</em> —
          Maori for “daughter of the water” — they left Melbourne in May 2007 bound north, then
          west. Through Indonesia and Borneo, the races of Miri and Phuket, across the Indian Ocean,
          up the Red Sea and through Suez to Turkey, then eventually homeward to the UK.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-muted dark:text-sand-200/75">
          The heart of this site is Peter’s log: long, wry, intimate emails to friends, preserved
          almost word for word. The photographs are of their time — small by modern standards —
          but they still carry the light of the voyage.
        </p>
      </div>
      <div class="relative">
        <img
          src="/images/LastSunsetINBassStrait.jpg"
          alt="Sunset in Bass Strait"
          class="rounded-2xl shadow-xl object-cover w-full aspect-[4/3]"
          loading="lazy"
        />
        <p class="mt-3 text-center text-sm text-muted dark:text-sand-200/60">Last sunset in Bass Strait</p>
      </div>
    </div>
  </section>

  <!-- Featured moments -->
  <section class="bg-sand-100/60 py-16 dark:bg-navy-900/50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-10 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
            Featured moments
          </p>
          <h2 class="mt-2 font-display text-3xl font-semibold text-navy-900 dark:text-sand-100">
            Three chapters worth diving into
          </h2>
        </div>
        <a href="/voyage/" class="hidden text-sm font-semibold text-teal-600 no-underline hover:underline sm:inline dark:text-teal-400">
          All logs →
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((log) => (
            <LogCard
              title={log.data.title}
              slug={log.data.slug}
              summary={log.data.summary}
              regionLabel={log.data.regionLabel}
              sequence={log.data.sequence}
              hero={log.data.hero}
              unfinished={log.data.unfinished}
              places={log.data.places}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div
      class="rounded-3xl bg-navy-900 px-8 py-12 text-center text-sand-100 dark:bg-navy-800 sm:px-12"
    >
      <h2 class="font-display text-3xl font-semibold">Leave a memory</h2>
      <p class="mx-auto mt-3 max-w-xl text-sand-200/80">
        Did you sail with them, meet them in a marina, or follow the voyage from shore? Sign the guestbook.
      </p>
      <a
        href="/guestbook/"
        class="mt-6 inline-flex rounded-full bg-teal-600 px-6 py-3 text-sm font-semibold text-white no-underline hover:bg-teal-500"
      >
        Open the guestbook
      </a>
    </div>
  </section>
</BaseLayout>
