---
/**
 * Ocean Odyssey v1.0.0
 * Designed by Colin Dixon + Grok
 * 2026-07-16 10:32:00 AEST (Melbourne)
 * Website by https://oze.au
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import VoyageMap from '../components/VoyageMap.astro';
---

<BaseLayout
  title="The Route — Ocean Odyssey Map | Hinewai’s Sailing Track"
  description="Interactive map of Hinewai’s voyage from Melbourne through Indonesia, Borneo, the Indian Ocean, the Red Sea and the Mediterranean — with links to each log."
  image="/images/MapPlanA.jpg"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">
        Geography of a voyage
      </p>
      <h1 class="mt-2 font-display text-4xl font-semibold text-navy-900 dark:text-sand-100">
        The route
      </h1>
      <p class="mt-4 text-lg text-muted dark:text-sand-200/75">
        It is said that the best laid plans of mice and men can come to naught — but you have to
        start somewhere. For them, that was Melbourne, Australia. Click a stop to fly there, or open
        the log for that leg of the voyage.
      </p>
    </header>

    <VoyageMap />
  </div>
</BaseLayout>
